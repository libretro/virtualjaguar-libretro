# Local E2E test build (downloads rcheevos tarball)
/build/

# Legacy local path (older CI recipe); keep ignored if present
/test_memory_map

# Build artifacts
*.o
*.so
*.dll
*.dylib
*.exe
*.js
*.bc

# Generated by scripts/gen-version-h.sh on every build
src/core/version.h

# macOS
.DS_Store
.build

# IDE / editor
/.claude
/.cursor
/.vscode

# Python virtual environments
.venv*/

# Test binaries and debug artifacts
test/test_blitter_simd
test/test_blitter_scalar
test/test_*
!test/test_*.c
!test/test_*.sh
!test/test_*.py
test/tools/test_memory_map
test/tools/sram_test
test/dump_caller
test/dump_pc
test/heap_search
test/*.dSYM/

# Test logs
*.log
test/*.log

# SRAM and CDROM save files (left at repo root by test harnesses
# that don't redirect the core's save path)
/*.srm
/*.cdrom.srm

# Test ROMs (keep source scripts, ignore binaries)
test/roms/*.jag
test/roms/*.rom
test/roms/private/

# Reference docs (large PDFs, not source)
docs/atari-jaguar-1999/

# LLDB scripts (local debug helpers)
test/lldb_*.cmd
test/lldb_*.py
/test/tools/test_benchmark
/test/tools/test_blitter_compare
/test/tools/test_screenshot
